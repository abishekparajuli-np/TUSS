"""
Firebase Security Rules for THERMASCAN AI

Deploy with:
  firebase deploy --only firestore:rules
"""

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDoctor() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isOwnData() {
      return resource.data.doctorId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (userId == request.auth.uid || isDoctor());
      allow write: if false; // Only admin can create users
    }

    // Patients collection
    match /patients/{patientId} {
      allow read: if isDoctor() && resource.data.doctorId == request.auth.uid;
      allow create: if isDoctor() && request.resource.data.doctorId == request.auth.uid;
      allow update: if isDoctor() && resource.data.doctorId == request.auth.uid;
      allow delete: if false; // Prevent deletion for audit trail
    }

    // Scans collection
    match /scans/{scanId} {
      allow read: if isDoctor() && resource.data.doctorId == request.auth.uid;
      allow create: if isDoctor() && request.resource.data.doctorId == request.auth.uid;
      allow update: if isDoctor() && resource.data.doctorId == request.auth.uid;
      allow delete: if false;
    }

    // Reports collection
    match /reports/{reportId} {
      allow read: if isDoctor() && resource.data.doctorId == request.auth.uid;
      allow create: if isDoctor() && request.resource.data.doctorId == request.auth.uid;
      allow update: if isDoctor() && resource.data.doctorId == request.auth.uid;
      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
